# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real keys.
#
# ── Oxylabs Web Scraper API (Amazon product/search via realtime API) ──────────
# Dashboard: https://dashboard.oxylabs.io/  |  Docs: https://developers.oxylabs.io/
# Used by scrape_top_affiliates.py and oxylabs-amazon-product.sh
OXYLABS_USERNAME=
OXYLABS_PASSWORD=
# ── Image generation (used by post_daily.py) ─────────────────────────────────
# Image Generation: ModelsLab (https://modelslab.com)
# Sign up at https://modelslab.com to get API key
# Free tier: 100 calls/day | Paid: $0.002/image or $29/month unlimited
MODELSLAB_KEY=your_modelslab_api_key_here
# Legacy (no longer used):
# FAL_KEY=  # Replaced by MODELSLAB_KEY for cost optimization
# Hugging Face token — required for local FLUX (--use-local-flux)
# Accept license at huggingface.co/black-forest-labs/FLUX.1-schnell, then get token at huggingface.co/settings/tokens
HF_TOKEN=
# Anthropic Claude haiku: writes tailored image prompts (optional — uses templates if absent)
ANTHROPIC_API_KEY=
# Cloudinary: image host for composed banners. Required — Instagram Graph API
# rejects i.ibb.co URLs (we tried; see commits 82cf6ab0/7dbbb8d1). Sign up at
# cloudinary.com (free tier covers our volume) and paste the API Environment
# Variable from the dashboard verbatim, e.g. cloudinary://KEY:SECRET@CLOUD_NAME
CLOUDINARY_URL=

# ── Social Media (used by post_daily.py) ─────────────────────────────────────
IG_USER_ID=    # numeric Instagram Business Account ID (not the username)
IG_ACCESS_TOKEN=

# TikTok Content Posting API (see RUNBOOK § TikTok token refresh for bootstrap).
# Access token expires in 24 h — refresh with `python -m tiktok_api refresh`.
# The refresh token rotates on each refresh; persist the new one or the next refresh fails.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=

# ── AI Ad Creative Pipeline (instagram/ad_creative_gen.py) ───────────────────
# Adapted from Samin Yasar "Claude Just Changed Marketing Forever" tutorial.
# Default banner path is the AI ad-creative (Gemini Nano Banana Pro grounded
# on Tavily reference images). Falls back to white-card on any failure.
#
# Gemini API key — image generation (Nano Banana Pro). Get at https://ai.dev/
GEMINI_API_KEY=
# Tavily API key — web image search for real-world reference grounding.
# Sign up at https://tavily.com/  (free tier covers daily rotation)
TAVILY_API_KEY=
# ScrapeCreators API key — competitor ad-library scraping (Level 3 feature).
# Sign up at https://scrapecreators.com/  Used by instagram/competitor_ads.py.
SCRAPECREATORS_API_KEY=
