# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real keys.
#
# ── Oxylabs Web Scraper API (Amazon product/search via realtime API) ──────────
# Dashboard: https://dashboard.oxylabs.io/  |  Docs: https://developers.oxylabs.io/
# Used by scrape_top_affiliates.py and oxylabs-amazon-product.sh
OXYLABS_USERNAME=
OXYLABS_PASSWORD=
# ── Image generation (used by post_daily.py) ─────────────────────────────────
# Image Generation: ModelsLab (https://modelslab.com)
# Sign up at https://modelslab.com to get API key
# Free tier: 100 calls/day | Paid: $0.002/image or $29/month unlimited
MODELSLAB_KEY=your_modelslab_api_key_here
# Legacy (no longer used):
# FAL_KEY=  # Replaced by MODELSLAB_KEY for cost optimization
# Anthropic Claude haiku: writes tailored image prompts (optional — uses templates if absent)
ANTHROPIC_API_KEY=
# imgbb: free image hosting so Instagram API can fetch the composed banner
# Get a free key at imgbb.com/api — required for full branded banner posting
# Without this, posts use the raw ModelsLab image URL instead
IMGBB_API_KEY=

# ── Social Media (used by post_daily.py) ─────────────────────────────────────
IG_USER_ID=    # numeric Instagram Business Account ID (not the username)
IG_ACCESS_TOKEN=
TIKTOK_ACCESS_TOKEN=
