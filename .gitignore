# Ignore all node_modules, generated files, and other unnecessary assets.
.github/workflows/deploy.yml
/node_modules/
/.next/
/dist/
/public/.next/
/public/dist/
/tmp/
/cache/
/build-cache/
!/*.js
!/*.css
!/*.html

# Claude Code settings (user-specific)
.claude/

# Logs
*.log
qa_output.log

# Build output (built in CI, not tracked in git)
site/out/
site/.next/

# Deploy archives (e.g. out.tar.gz from npm run deploy:zip)
*.tar.gz
*.zip

# Tool caches
.ruff_cache/
.pytest_cache/
.mypy_cache/

# Personal/scratch directories
.remember/

# Local secrets — never commit API keys
.env
.env.*
!.env.example
# SSH keys / TLS certs / generic credential files
*.pem
*.key
*_rsa
*_rsa.pub
*_ed25519
*_ed25519.pub
id_*
credentials*
secrets*
auth.json

# Python cache
__pycache__/
*.pyc

# OMC runtime files (session state, not source)
.omc/sessions/
.omc/state/
.omc/project-memory.json
site/.omc/

# Python virtual environments
venv/
.venv/
env/
.fal_test_venv/
.gen-venv/

# Generated media (output artifacts, not source)
generated_images/
generated_videos/

# Local-only project subdirs
paperclip-company/

# CSV backups (timestamped copies, not source)
products/top-1000.backup.*.csv

# Bestseller-discovery output (regenerated per run; not source)
products/discovery/

# Windows batch helpers (local-only)
push-seo-fixes.bat

# Link report artifact
link-report.json
