# Growth Engine env vars. Most are also set in repo-root .env — this file
# just documents what the engine itself reads.

# --- Required ---
ANTHROPIC_API_KEY=        # https://console.anthropic.com/settings/keys

# --- Optional, enable additional features ---
OPENAI_API_KEY=           # Adds GPT to AI visibility tracker
PERPLEXITY_API_KEY=       # Adds Perplexity to AI visibility tracker
TAVILY_API_KEY=           # Used by keyword research + backlink finder for live web search
                          # (already set in repo .env if you use Instagram pipeline)
SERPER_API_KEY=           # Alternative SERP API (Google) — falls back to Tavily if unset

# --- Outreach / publishing ---
GITHUB_REPO=hotproductsdot-v2  # used in commit messages (cosmetic)

# --- Engine behavior overrides ---
GROWTH_ENGINE_DRY_RUN=    # set to "1" to force dry-run mode globally
